{
  "name": "voterspheres-backend", 
  "version": "1.0.0",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev": "node index.js",
    "dev:clean": "kill-port 10000 && node index.js",
    "start": "node index.js",
    "start:clean": "kill-port 10000 && node index.js",
    "restart": "npm run start:clean",
    "check:api": "powershell -Command \"Invoke-WebRequest http://127.0.0.1:10000/api/health -UseBasicParsing | Select-Object StatusCode, StatusDescription\"",
    "db:migrate": "node db/runMigrations.js",
    "db:seed": "node db/seed.js",
    "db:init": "npm run db:migrate && npm run db:seed",
    "ingest:once": "node jobs/providerIngestion.jobRunner.js",
    "sync:fec": "node scripts/syncFecData.js"
  },
  "dependencies": {
    "axios": "^1.13.5",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "csv-parser": "^3.2.0",
    "dotenv": "^17.3.1",
    "express": "^4.22.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "pg": "^8.20.0",
    "redis": "^5.10.0",
    "slugify": "^1.6.6",
    "socket.io": "^4.8.3",
    "stripe": "^20.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.3.2",
    "kill-port": "^2.0.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  }
}
